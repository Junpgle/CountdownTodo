{
  "package": "com.math_quiz.junpgle.com.math_quiz_app",
  "name": "CountDownTodo",
  "versionName": "1.0.0",
  "versionCode": 1,
  "minPlatformVersion": 1000,
  "icon": "/common/logo.png",
  "deviceTypeList": [
    "watch"
  ],
  "features": [
    {
      "name": "system.router"
    },
    {
      "name": "system.prompt"
    },
    {
      "name": "system.storage"
    },
    {
      "name": "system.interconnect"
    }
  ],
  "config": {
    "logLevel": "log"
  },
  "router": {
    "entry": "pages/index",
    "pages": {
      "pages/index": {
        "component": "index"
      },
      "pages/list": {
        "component": "list"
      },
      "pages/add": {
        "component": "add"
      },
      "pages/countdown": {
        "component": "countdown"
      },
      "pages/todo": {
        "component": "todo"
      },
      "pages/course": {
        "component": "course"
      }
    }
  }
}