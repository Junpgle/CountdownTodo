  flex: 1;
  flex-direction: column;
}

.module-card {
  flex-direction: row;
  align-items: center;
  background-color: #262626;
  border-radius: 999px;
  height: 120px;
  flex-shrink: 0;
  margin-bottom: 28px;
}

.module-icon-wrap {
  width: 130px;
  height: 100%;
  border-radius: 999px;
  justify-content: center;
  align-items: center;
}

.module-icon {
  font-size: 35px;
  font-weight: bold;
  color: #ffffff;
}

.todo-bg { background-color: #4a90d9; }
.countdown-bg { background-color: #e67e22; }
.course-bg { background-color: #27ae60; }
.settings-bg { background-color: #555555; }
.danger-bg { background-color: #3a1111; }

.module-info {
  flex: 1;
  flex-direction: column;
  justify-content: center;
  margin-left: 24px;
}

.module-title {
  font-size: 35px;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 6px;
}

.module-desc {
  font-size: 30px;
  color: #888888;
}

.arrow {
  font-size: 40px;
  color: #888888;
  margin-right: 36px;
}

.danger-text {
  color: #ff4d4f;
}

.version-info {
  align-items: center;
  justify-content: center;
  margin-top: 24px;
  margin-bottom: 48px;
  flex-shrink: 0;
}

.version-text {
  font-size: 24px;
  color: #777777;
}
</style>
