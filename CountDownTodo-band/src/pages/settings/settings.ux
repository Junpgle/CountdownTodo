<template>
  <div class="page">

    <!-- 顶部导航栏 (固定不动) -->
    <div class="header">
      <text class="back-btn" onclick="goBack">‹</text>
      <text class="title" static>设置</text>
      <div class="placeholder"></div>
    </div>

    <!-- 设置内容区 (支持上下滑动) -->
    <list class="content">

      <!-- 存储信息 -->
      <list-item type="info" class="module-card">
        <div class="module-icon-wrap settings-bg">
          <text class="module-icon" static>MEM</text>
        </div>
        <div class="module-info">
          <text class="module-title" static>存储空间</text>
          <text class="module-desc">已用 {{cacheSize}} · {{dataCount}} 项</text>
        </div>
      </list-item>

      <!-- 清理待办 -->
      <list-item type="action" class="module-card" onclick="clearTodoCache">
        <div class="module-icon-wrap todo-bg">
          <text class="module-icon" static>TODO</text>
        </div>
        <div class="module-info">
          <text class="module-title" static>清除待办</text>
          <text class="module-desc" static>删除所有待办数据</text>
        </div>
        <text class="arrow" static>›</text>
      </list-item>

      <!-- 清理倒数日 -->
      <list-item type="action" class="module-card" onclick="clearCountdownCache">
        <div class="module-icon-wrap countdown-bg">
          <text class="module-icon" static>DAY</text>
        </div>
        <div class="module-info">
          <text class="module-title" static>清除倒数日</text>
          <text class="module-desc" static>删除所有倒数日数据</text>
        </div>
        <text class="arrow" static>›</text>
      </list-item>

      <!-- 清理课程表 -->
      <list-item type="action" class="module-card" onclick="clearCourseCache">
        <div class="module-icon-wrap course-bg">
          <text class="module-icon" static>CLS</text>
        </div>
        <div class="module-info">
          <text class="module-title" static>清除课程</text>
          <text class="module-desc" static>删除所有课程数据</text>
        </div>
        <text class="arrow" static>›</text>
      </list-item>

      <!-- 危险操作：清除全部 -->
      <list-item type="danger" class="module-card" onclick="clearAllCache">
        <div class="module-icon-wrap danger-bg">
          <text class="module-icon" static>WARN</text>
        </div>
        <div class="module-info">
          <text class="module-title danger-text" static>清除所有数据</text>
          <text class="module-desc danger-text" static>此操作不可恢复</text>
        </div>
        <text class="arrow danger-text" static>›</text>
      </list-item>

      <!-- 版本信息 -->
      <list-item type="version" class="version-info">
        <text class="version-text">CDT {{version}}</text>
      </list-item>

    </list>
  </div>
</template>

<script>
import router from '@system.router'
import prompt from '@system.prompt'
import storage from '@system.storage'

export default {
  data: {
    cacheSize: '0 KB',
    dataCount: '0',
    version: '1.0.0'
  },

  onInit() {
    this.loadCacheInfo()
  },

  onShow() {
    this.loadCacheInfo()
  },

  onDestroy() {
    global.runGC()
  },

  loadCacheInfo() {
    let totalItems = 0
    let totalSize = 0
    let checked = 0
    const total = 3

    const checkDone = () => {
      checked++
      if (checked >= total) {
        this.updateCacheDisplay(totalSize, totalItems)
      }
    }

    storage.get({
      key: 'sync_todo',
      success: (data) => {
        if (data) {
          totalSize += data.length
          try {
            const parsed = JSON.parse(data)
            if (Array.isArray(parsed)) totalItems += parsed.length
          } catch (e) {}
        }
        checkDone()
      },
      fail: () => { checkDone() }
    })

    storage.get({
      key: 'sync_countdown',
      success: (data) => {
        if (data) {
          totalSize += data.length
          try {
            const parsed = JSON.parse(data)
            if (Array.isArray(parsed)) totalItems += parsed.length
          } catch (e) {}
        }
        checkDone()
      },
      fail: () => { checkDone() }
    })

    storage.get({
      key: 'sync_course',
      success: (data) => {
        if (data) {
          totalSize += data.length
          try {
            const parsed = JSON.parse(data)
            if (Array.isArray(parsed)) totalItems += parsed.length
          } catch (e) {}
        }
        checkDone()
      },
      fail: () => { checkDone() }
    })
  },

  updateCacheDisplay(size, count) {
    if (size < 1024) {
      this.cacheSize = size + ' B'
    } else if (size < 1024 * 1024) {
      this.cacheSize = (size / 1024).toFixed(1) + ' KB'
    } else {
      this.cacheSize = (size / (1024 * 1024)).toFixed(2) + ' MB'
    }
    this.dataCount = count.toString()
  },

  goBack() {
    router.back()
  },

  clearTodoCache() {
    storage.delete({
      key: 'sync_todo',
      success: () => {
        prompt.showToast({ message: '待办已清除' })
        this.loadCacheInfo()
      },
      fail: () => {
        prompt.showToast({ message: '清除失败' })
      }
    })
  },

  clearCountdownCache() {
    storage.delete({
      key: 'sync_countdown',
      success: () => {
        prompt.showToast({ message: '倒数日已清除' })
        this.loadCacheInfo()
      },
      fail: () => {
        prompt.showToast({ message: '清除失败' })
      }
    })
  },

  clearCourseCache() {
    storage.delete({
      key: 'sync_course',
      success: () => {
        prompt.showToast({ message: '课程已清除' })
        this.loadCacheInfo()
      },
      fail: () => {
        prompt.showToast({ message: '清除失败' })
      }
    })
  },

  clearAllCache() {
    const keys = ['sync_todo', 'sync_countdown', 'sync_course']
    const deleteNext = (index) => {
      if (index >= keys.length) {
        prompt.showToast({ message: '所有数据已清除' })
        this.loadCacheInfo()
        return
      }
      storage.delete({
        key: keys[index],
        success: () => { deleteNext(index + 1) },
        fail: () => { deleteNext(index + 1) }
      })
    }
    deleteNext(0)
  }
}
</script>

