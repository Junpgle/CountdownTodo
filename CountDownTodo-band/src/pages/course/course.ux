  font-size: 20px;
  color: #ffffffaa;
  margin-top: 8px;
}

/* 课程列表 */
.list {
  flex: 1;
}

.item {
  flex-direction: row;
  margin-bottom: 12px;
}

/* 时间列 */
.time-column {
  width: 80px;
  align-items: center;
  margin-right: 24px;
}

.start-time {
  font-size: 24px;
  font-weight: bold;
  color: #ffffff;
}

.time-line {
  width: 5px;
  flex: 1;
  background-color: #ffffff40;
  margin: 10px 0;
  min-height: 32px;
}

.end-time {
  font-size: 17px;
  color: #ffffffaa;
}

/* 课程卡片 */
.course-card {
  flex: 1;
  background-color: #333333;
  border-radius: 26px;
  padding: 26px;
}

.course-card.ongoing {
  border-left-width: 4px;
  border-left-color: #4caf50;
}

.course-card.ended {
  opacity: 0.6;
}

.course-header {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.course-name {
  font-size: 26px;
  font-weight: bold;
  color: #ffffff;
  flex: 1;
}

.course-status {
  font-size: 17px;
  color: #ffffff;
  background-color: #555555;
  padding: 8px 16px;
  border-radius: 14px;
}

/* 课程详情 */
.course-details {
  margin-bottom: 8px;
}

.detail-item {
  flex-direction: row;
  align-items: center;
  margin-bottom: 8px;
}

.detail-icon {
  font-size: 18px;
