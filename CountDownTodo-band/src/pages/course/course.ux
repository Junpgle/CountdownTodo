  flex-direction: column;
}

.empty-icon-wrap {
  width: 100px;
  height: 100px;
  border-radius: 50px;
  background-color: #ffffff20;
  justify-content: center;
  align-items: center;
  margin-bottom: 24px;
}

.empty-icon {
