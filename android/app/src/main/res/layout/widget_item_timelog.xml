<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp">

    <TextView android:id="@+id/tl_title" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="13sp" android:maxLines="1" android:ellipsize="end" android:layout_marginEnd="10dp"/>
    <TextView android:id="@+id/tl_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#10B981" android:textSize="13sp" android:textStyle="bold"/>

</LinearLayout>