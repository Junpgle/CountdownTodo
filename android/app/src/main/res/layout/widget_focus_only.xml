<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 动态背景层 -->
    <ImageView
        android:id="@+id/widget_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_bg_modern"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <LinearLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!-- 标题区域 -->
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="专注记录"
            android:textColor="#111827"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <!-- 专注状态栏 -->
        <LinearLayout
            android:id="@+id/focus_active_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="6dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/focus_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1F2937"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/focus_timer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#3B82F6"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/focus_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#10B981"
                android:textSize="11sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- 今日专注总时长 -->
        <TextView
            android:id="@+id/tl_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="今日专注: 0 分钟"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"
            android:textStyle="bold" />

        <!-- 专注记录列表 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ListView
                android:id="@+id/list_timelogs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"
                android:scrollbars="none"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/empty_timelogs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="暂无专注记录"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
