<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 动态背景层 -->
    <ImageView
        android:id="@+id/widget_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_bg_modern"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <LinearLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp">

        <!-- 标题区域 -->
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="专注记录"
            android:textColor="@color/widget_text_primary"
            android:textSize="14.5sp"
            android:textStyle="bold"
            android:paddingBottom="10dp"
            android:includeFontPadding="false" />

        <!-- 正在专注卡片 -->
        <LinearLayout
            android:id="@+id/focus_active_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/widget_focus_active_bg"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/focus_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/focus_timer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/focus_timer_color"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/focus_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/focus_tag_text"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- 今日专注总时长 -->
        <TextView
            android:id="@+id/tl_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="今日专注: 0 分钟"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11.5sp"
            android:layout_marginBottom="6dp"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <!-- 专注记录列表 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ListView
                android:id="@+id/list_timelogs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"
                android:scrollbars="none"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/empty_timelogs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="暂无专注记录"
                android:textColor="@color/widget_text_secondary"
                android:textSize="13sp"
                android:visibility="gone"
                android:includeFontPadding="false" />
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
