<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="8dp">

    <TextView android:id="@+id/course_date" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#9CA3AF" android:textSize="11sp" android:textStyle="bold"/>
    <TextView android:id="@+id/course_name" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
    <TextView android:id="@+id/course_time" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#6B7280" android:textSize="12sp" android:layout_marginTop="2dp"/>
    <TextView android:id="@+id/course_room" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="1dp" />

</LinearLayout>