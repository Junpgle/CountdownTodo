            <LinearLayout android:id="@+id/cd_layout_8" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="6dp" android:visibility="gone"><TextView android:id="@+id/cd_title_8" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="13sp" android:maxLines="1" android:ellipsize="end"/><TextView android:id="@+id/cd_days_8" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#3B82F6" android:textSize="14sp" android:textStyle="bold"/></LinearLayout>
        </LinearLayout>

        <!-- Page 3: 专注记录 -->
        <LinearLayout android:id="@+id/page_timelogs" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="gone">
            <TextView android:id="@+id/tl_total" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="今日专注: 0 分钟" android:textColor="#6B7280" android:textSize="12sp" android:layout_marginBottom="4dp" android:textStyle="bold"/>
            <LinearLayout android:id="@+id/tl_empty_layout" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="暂无专注记录" android:textColor="#9CA3AF" android:textSize="13sp"/></LinearLayout>
            <LinearLayout android:id="@+id/tl_layout_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="6dp" android:visibility="gone"><TextView android:id="@+id/tl_title_1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="13sp" android:maxLines="1" android:ellipsize="end"/><TextView android:id="@+id/tl_time_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#10B981" android:textSize="13sp" android:textStyle="bold"/></LinearLayout>
