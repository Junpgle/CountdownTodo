            <LinearLayout android:id="@+id/cd_layout_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="6dp" android:visibility="gone"><TextView android:id="@+id/cd_title_2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="13sp" android:maxLines="1" android:ellipsize="end"/><TextView android:id="@+id/cd_days_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#3B82F6" android:textSize="14sp" android:textStyle="bold"/></LinearLayout>
            <LinearLayout android:id="@+id/cd_layout_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="6dp" android:visibility="gone"><TextView android:id="@+id/cd_title_3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="13sp" android:maxLines="1" android:ellipsize="end"/><TextView android:id="@+id/cd_days_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#3B82F6" android:textSize="14sp" android:textStyle="bold"/></LinearLayout>
            <LinearLayout android:id="@+id/cd_layout_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="6dp" android:visibility="gone"><TextView android:id="@+id/cd_title_4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="13sp" android:maxLines="1" android:ellipsize="end"/><TextView android:id="@+id/cd_days_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#3B82F6" android:textSize="14sp" android:textStyle="bold"/></LinearLayout>
            <LinearLayout android:id="@+id/cd_layout_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="6dp" android:visibility="gone"><TextView android:id="@+id/cd_title_5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="13sp" android:maxLines="1" android:ellipsize="end"/><TextView android:id="@+id/cd_days_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#3B82F6" android:textSize="14sp" android:textStyle="bold"/></LinearLayout>
