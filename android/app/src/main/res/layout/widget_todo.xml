            <LinearLayout android:id="@+id/course_layout_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingVertical="8dp" android:visibility="gone"><TextView android:id="@+id/course_date_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#9CA3AF" android:textSize="11sp" android:textStyle="bold"/><TextView android:id="@+id/course_name_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp"/><TextView android:id="@+id/course_time_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#6B7280" android:textSize="12sp" android:layout_marginTop="1dp"/><TextView android:id="@+id/course_room_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#6B7280" android:textSize="12sp" /></LinearLayout>
            <LinearLayout android:id="@+id/course_layout_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingVertical="8dp" android:visibility="gone"><TextView android:id="@+id/course_date_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#9CA3AF" android:textSize="11sp" android:textStyle="bold"/><TextView android:id="@+id/course_name_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp"/><TextView android:id="@+id/course_time_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#6B7280" android:textSize="12sp" android:layout_marginTop="1dp"/><TextView android:id="@+id/course_room_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#6B7280" android:textSize="12sp" /></LinearLayout>
            <LinearLayout android:id="@+id/course_layout_7" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingVertical="8dp" android:visibility="gone"><TextView android:id="@+id/course_date_7" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#9CA3AF" android:textSize="11sp" android:textStyle="bold"/><TextView android:id="@+id/course_name_7" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp"/><TextView android:id="@+id/course_time_7" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#6B7280" android:textSize="12sp" android:layout_marginTop="1dp"/><TextView android:id="@+id/course_room_7" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#6B7280" android:textSize="12sp" /></LinearLayout>
            <LinearLayout android:id="@+id/course_layout_8" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingVertical="8dp" android:visibility="gone"><TextView android:id="@+id/course_date_8" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#9CA3AF" android:textSize="11sp" android:textStyle="bold"/><TextView android:id="@+id/course_name_8" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#1F2937" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp"/><TextView android:id="@+id/course_time_8" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#6B7280" android:textSize="12sp" android:layout_marginTop="1dp"/><TextView android:id="@+id/course_room_8" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#6B7280" android:textSize="12sp" /></LinearLayout>
        </LinearLayout>

