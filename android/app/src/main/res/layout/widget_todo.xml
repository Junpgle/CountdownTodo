    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Page 0: 待办清单 -->
        <LinearLayout android:id="@+id/page_todos" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
            <!-- 槽位 1-8 -->
            <LinearLayout android:id="@+id/todo_layout_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="5dp" android:visibility="gone"><ImageView android:id="@+id/todo_checkbox_1" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/widget_checkbox_empty" /><TextView android:id="@+id/todo_text_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:ellipsize="end" android:maxLines="1" android:textColor="#1F2937" android:textSize="13sp" /><TextView android:id="@+id/todo_due_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="11sp" android:textStyle="bold" android:visibility="gone" /></LinearLayout>
            <LinearLayout android:id="@+id/todo_layout_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="5dp" android:visibility="gone"><ImageView android:id="@+id/todo_checkbox_2" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/widget_checkbox_empty" /><TextView android:id="@+id/todo_text_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:ellipsize="end" android:maxLines="1" android:textColor="#1F2937" android:textSize="13sp" /><TextView android:id="@+id/todo_due_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="11sp" android:textStyle="bold" android:visibility="gone" /></LinearLayout>
            <LinearLayout android:id="@+id/todo_layout_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="5dp" android:visibility="gone"><ImageView android:id="@+id/todo_checkbox_3" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/widget_checkbox_empty" /><TextView android:id="@+id/todo_text_3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:ellipsize="end" android:maxLines="1" android:textColor="#1F2937" android:textSize="13sp" /><TextView android:id="@+id/todo_due_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="11sp" android:textStyle="bold" android:visibility="gone" /></LinearLayout>
            <LinearLayout android:id="@+id/todo_layout_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="5dp" android:visibility="gone"><ImageView android:id="@+id/todo_checkbox_4" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/widget_checkbox_empty" /><TextView android:id="@+id/todo_text_4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:ellipsize="end" android:maxLines="1" android:textColor="#1F2937" android:textSize="13sp" /><TextView android:id="@+id/todo_due_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="11sp" android:textStyle="bold" android:visibility="gone" /></LinearLayout>
            <LinearLayout android:id="@+id/todo_layout_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="5dp" android:visibility="gone"><ImageView android:id="@+id/todo_checkbox_5" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/widget_checkbox_empty" /><TextView android:id="@+id/todo_text_5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:ellipsize="end" android:maxLines="1" android:textColor="#1F2937" android:textSize="13sp" /><TextView android:id="@+id/todo_due_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="11sp" android:textStyle="bold" android:visibility="gone" /></LinearLayout>
            <LinearLayout android:id="@+id/todo_layout_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="5dp" android:visibility="gone"><ImageView android:id="@+id/todo_checkbox_6" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/widget_checkbox_empty" /><TextView android:id="@+id/todo_text_6" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:ellipsize="end" android:maxLines="1" android:textColor="#1F2937" android:textSize="13sp" /><TextView android:id="@+id/todo_due_6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="11sp" android:textStyle="bold" android:visibility="gone" /></LinearLayout>
            <LinearLayout android:id="@+id/todo_layout_7" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="5dp" android:visibility="gone"><ImageView android:id="@+id/todo_checkbox_7" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/widget_checkbox_empty" /><TextView android:id="@+id/todo_text_7" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:ellipsize="end" android:maxLines="1" android:textColor="#1F2937" android:textSize="13sp" /><TextView android:id="@+id/todo_due_7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="11sp" android:textStyle="bold" android:visibility="gone" /></LinearLayout>
            <LinearLayout android:id="@+id/todo_layout_8" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="5dp" android:visibility="gone"><ImageView android:id="@+id/todo_checkbox_8" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/widget_checkbox_empty" /><TextView android:id="@+id/todo_text_8" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:ellipsize="end" android:maxLines="1" android:textColor="#1F2937" android:textSize="13sp" /><TextView android:id="@+id/todo_due_8" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="11sp" android:textStyle="bold" android:visibility="gone" /></LinearLayout>
        </LinearLayout>

